# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://kiosque:kiosque_dev_password@localhost:5433/kiosque_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Logger
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
